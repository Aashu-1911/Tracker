# Server
PORT=5000

# MongoDB
# Local example: mongodb://127.0.0.1:27017/tracker
# Atlas example: mongodb+srv://<username>:<password>@cluster>.mongodb.net/tracker
MONGODB_URI=

# AI — use ONE provider (or both; Gemini keys are auto-detected)
# Google Gemini (keys start with AIza… or AQ.…)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (keys start with sk-…)
OPENAI_API_KEY=
OPENAI_API_KEY1=
OPENAI_API_KEY2=
OPENAI_MODEL=gpt-4o-mini
